/*
* There are 46 trip levels and cooling maps so cooling-levels
* must have exactly 46 elements. If greater increments between
* trip levels/cooling-levels are desired/needed, pad the
* cooling-levels with repeated values:
* 	cooling-levels = <... 128 128 128 192 192 192 ...>;
*
* THERMAL_TRIPS_COMMON and THERMAL_COOLING_MAPS_COMMON must have
* the same argument within a thermal zone because the argument
* is the prefix to the trip levels node aliases.
*
* example:
* / {
* 	...
* 	thermal-zones {
* 		wifi0-thermal {
* 			thermal-sensors = <&wifi 0>;
* 			polling-delay-passive = <1000>;
* 			polling-delay = <1000>;
*
* 			trips {
* 				THERMAL_TRIPS_COMMON(wifi0)
* 			};
*
* 			cooling-maps {
* 				THERMAL_COOLING_MAPS_COMMON(wifi0)
* 			};
* 		};
*
* 		wifi1-thermal {
* 			thermal-sensors = <&wifi 1>;
* 			polling-delay-passive = <1000>;
* 			polling-delay = <1000>;
*
* 			trips {
* 				THERMAL_TRIPS_COMMON(wifi1)
* 			};
*
* 			cooling-maps {
* 				THERMAL_COOLING_MAPS_COMMON(wifi1)
* 			};
* 		};
* 	};
* 	...
* };
*/

